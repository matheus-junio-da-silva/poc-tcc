{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./_bmad/core/bmad-help/SKILL.md",
    "./_bmad/_config/skill-manifest.csv",
    "./AGENTS.md"
  ],
  "agent": {
    "build": {
      "permission": {
        "bash": "allow",
        "edit": "allow"
      }
    }
  },
  "command": {
    "audit:access-control": {
      "template": "Execute o pipeline completo de auditoria de Access Control usando o orquestrador dedicado:\n@certora-orchestrator",
      "description": "Pipeline completo de auditoria formal de Access Control (Slither + Certora + PoC)"
    }
  }
}
