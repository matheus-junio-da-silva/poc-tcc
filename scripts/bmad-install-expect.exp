#!/usr/bin/expect -f
# bmad-install-expect.exp v6
# Fluxo de MODIFICAÇÃO (instalação existente) para adicionar OpenCode
# Fluxo confirmado pelos logs anteriores:
# 1. Installation directory → Enter
# 2. Install to this directory? → Enter (Yes)
# 3. How would you like to proceed? → Enter (Modify BMAD Installation)
# 4. Integrate with (adicionar OpenCode) → navegar + espaço + Enter
# 5. Confirmation → Enter

set timeout 180
set project_dir "/home/mat/poc1novo/poc-tcc"

spawn bash -c "stty rows 40 cols 120; cd $project_dir && npx --yes bmad-method install"

# ─── 1. Installation directory ───────────────────────────────────────────────
expect {
    -re {Installation directory} { sleep 1.0; send "\r" }
    timeout { puts "T1"; exit 1 }
}

# ─── 2. Install to this directory? ───────────────────────────────────────────
expect {
    -re {Install to this directory} { sleep 1.0; send "\r" }
    timeout { puts "T2"; exit 1 }
}

# ─── 3. How would you like to proceed? (Modify / Fresh install) ──────────────
# Aqui aparece porque já existe instalação. Selecionar "Modify BMAD Installation"
expect {
    -re {How would you like to proceed} {
        sleep 1.0
        send "\r"  ;# Enter = aceitar a opção destacada (Modify)
    }
    # Se não aparecer (raro), continuar
    -re {Select official modules} { sleep 0.5; send "\r" }
    timeout { puts "T3"; exit 1 }
}

# ─── 4. Select tools to integrate ────────────────────────────────────────────
# Após "Modify", vai direto para seleção de ferramentas
expect {
    -re {Integrate with|tool|Tool|IDE} {
        sleep 2.0
        # A lista de IDEs — OpenCode está após:
        # Claude Code (0), Codex (1), Cursor (2), GitHub Copilot (3), AdaL (4),
        # Auggie (5), Block Goose (6), Cline (7), Continue (8), Gemini CLI (9),
        # Kilo Code (10), OpenCode (11??)...
        # Vamos usar busca digitando "Open"
        send "Open"
        sleep 1.5
        # Selecionar o primeiro resultado com espaço
        send " "
        sleep 0.5
        # Confirmar com Enter
        send "\r"
    }
    timeout { puts "T4"; exit 1 }
}

# ─── 5. Prompts restantes — responder Enter ───────────────────────────────────
set done 0
set i 0
while { !$done && $i < 20 } {
    expect {
        -re {◆} {
            sleep 1.0
            send "\r"
            incr i
        }
        -re {complete|success|installed|finished|Done} {
            puts "\n✓ Integração OpenCode adicionada!"
            set done 1
        }
        eof {
            puts "\n✓ EOF após $i prompts"
            set done 1
        }
        timeout {
            puts "\nTimeout após $i prompts"
            set done 1
        }
    }
}

catch { wait }
puts "Script v6 concluído."
